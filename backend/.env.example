# ============================================
# 顶呱呱AI宝 - 后端环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================

# Node 环境
NODE_ENV=development

# 服务端口
PORT=3000

# 前端URL（跨域白名单）
FRONTEND_URL=http://localhost:5173

# ============================================
# MongoDB
# ============================================
MONGODB_URI=mongodb://localhost:27017/dinggg
MONGODB_USER=
MONGODB_PASSWORD=

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ============================================
# JWT
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# 微信小程序
# ============================================
WECHAT_APPID=your-wechat-appid
WECHAT_SECRET=your-wechat-secret

# ============================================
# MiniMax AI
# ============================================
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_GROUP_ID=your-minimax-group-id

# MiniMax API 地址（国内版）
MINIMAX_BASE_URL=https://api.minimax.chat

# ============================================
# 微信支付（商户平台）
# ============================================
WECHAT_PAY_MCHID=your-merchant-id
WECHAT_PAY_API_KEY=your-payment-api-key
WECHAT_PAY_APPID=your-wechat-appid
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/payment/callback

# ============================================
# 文件存储（阿里云OSS）
# ============================================
OSS_ACCESS_KEY_ID=your-access-key
OSS_ACCESS_KEY_SECRET=your-secret-key
OSS_BUCKET=dinggg-ai-assets
OSS_REGION=cn-shanghai
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com

# ============================================
# 日志
# ============================================
LOG_LEVEL=info
LOG_DIR=./logs

# ============================================
# 接口限流
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# 免费用户每日配额
FREE_USER_DAILY_QUOTA=3
